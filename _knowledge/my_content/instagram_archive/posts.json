          },
          "title": "\u00d0\u00a2\u00d1\u008b \u00d0\u00b4\u00d0\u00be\u00d0\u00bb\u00d0\u00b3\u00d0\u00be \u00d0\u00b4\u00d1\u0083\u00d0\u00bc\u00d0\u00b0\u00d0\u00b5\u00d1\u0088\u00d1\u008c \u00d0\u00be \u00d1\u0082\u00d0\u00b5\u00d1\u0080\u00d0\u00b0\u00d0\u00bf\u00d0\u00b8\u00d0\u00b8, \u00d0\u00bd\u00d0\u00be \u00d0\u00b4\u00d0\u00b5\u00d1\u0080\u00d0\u00b6\u00d0\u00b8\u00d1\u0088\u00d1\u008c \u00d0\u00b4\u00d0\u00b8\u00d1\u0081\u00d1\u0082\u00d0\u00b0\u00d0\u00bd\u00d1\u0086\u00d0\u00b8\u00d1\u008e?\n\n\u00d0\u00af \u00d1\u008d\u00d1\u0082\u00d0\u00be \u00d0\u00bf\u00d0\u00be\u00d0\u00bd\u00d0\u00b8\u00d0\u00bc\u00d0\u00b0\u00d1\u008e. \u00d0\u009f\u00d0\u00b5\u00d1\u0080\u00d0\u00b2\u00d1\u008b\u00d0\u00b9 \u00d1\u0080\u00d0\u00b0\u00d0\u00b7 \u00d0\u00b2\u00d1\u0081\u00d0\u00b5\u00d0\u00b3\u00d0\u00b4\u00d0\u00b0 \u00d0\u00bf\u00d1\u0083\u00d0\u00b3\u00d0\u00b0\u00d0\u00b5\u00d1\u0082. \u00d0\u009c\u00d0\u00be\u00d0\u00b6\u00d0\u00b5\u00d1\u0082 \u00d0\u00b1\u00d1\u008b\u00d1\u0082\u00d1\u008c, \u00d1\u0081\u00d1\u0082\u00d1\u0080\u00d0\u00b0\u00d1\u0088\u00d0\u00bd\u00d0\u00be \u00d1\u0087\u00d1\u0082\u00d0\u00be-\u00d1\u0082\u00d0\u00be \u00d0\u00b2\u00d1\u0081\u00d0\u00bf\u00d0\u00be\u00d0\u00bc\u00d0\u00bd\u00d0\u00b8\u00d1\u0082\u00d1\u008c. \u00d0\u0098\u00d0\u00bb\u00d0\u00b8 \u00d1\u0081\u00d1\u0082\u00d1\u008b\u00d0\u00b4\u00d0\u00bd\u00d0\u00be \u00d0\u00b3\u00d0\u00be\u00d0\u00b2\u00d0\u00be\u00d1\u0080\u00d0\u00b8\u00d1\u0082\u00d1\u008c \u00d0\u00be \u00d1\u0081\u00d0\u00b2\u00d0\u00be\u00d1\u0091\u00d0\u00bc. \u00d0\u0098\u00d0\u00bb\u00d0\u00b8 \u00d0\u00bf\u00d1\u0080\u00d0\u00be\u00d1\u0081\u00d1\u0082\u00d0\u00be \u00d0\u00bd\u00d0\u00b5 \u00d0\u00b7\u00d0\u00bd\u00d0\u00b0\u00d0\u00b5\u00d1\u0088\u00d1\u008c, \u00d1\u0087\u00d1\u0082\u00d0\u00be \u00d0\u00be\u00d0\u00b6\u00d0\u00b8\u00d0\u00b4\u00d0\u00b0\u00d1\u0082\u00d1\u008c.\n\n\u00d0\u0092\u00d0\u00be\u00d1\u0082 \u00d1\u0087\u00d1\u0082\u00d0\u00be \u00d0\u00bf\u00d1\u0080\u00d0\u00be\u00d0\u00b8\u00d1\u0081\u00d1\u0085\u00d0\u00be\u00d0\u00b4\u00d0\u00b8\u00d1\u0082 \u00d0\u00bd\u00d0\u00b0 \u00d1\u0081\u00d0\u00b5\u00d1\u0081\u00d1\u0081\u00d0\u00b8\u00d0\u00b8 \u00d0\u00bd\u00d0\u00b0 \u00d1\u0081\u00d0\u00b0\u00d0\u00bc\u00d0\u00be\u00d0\u00bc \u00d0\u00b4\u00d0\u00b5\u00d0\u00bb\u00d0\u00b5:\n\n\u00d0\u00a2\u00d1\u008b \u00d1\u0080\u00d0\u00b0\u00d1\u0081\u00d1\u0081\u00d0\u00ba\u00d0\u00b0\u00d0\u00b7\u00d1\u008b\u00d0\u00b2\u00d0\u00b0\u00d0\u00b5\u00d1\u0088\u00d1\u008c. \u00d0\u00af \u00d1\u0081\u00d0\u00bb\u00d1\u0083\u00d1\u0088\u00d0\u00b0\u00d1\u008e. \u00d0\u0091\u00d0\u00b5\u00d0\u00b7 \u00d1\u0081\u00d1\u0083\u00d0\u00b4\u00d0\u00b0. \u00d0\u0091\u00d0\u00b5\u00d0\u00b7 \u00d1\u0081\u00d0\u00be\u00d0\u00b2\u00d0\u00b5\u00d1\u0082\u00d0\u00b0, \u00d0\u00ba\u00d0\u00be\u00d1\u0082\u00d0\u00be\u00d1\u0080\u00d1\u008b\u00d0\u00b9 \u00d0\u00bd\u00d0\u00b5 \u00d0\u00bf\u00d1\u0080\u00d0\u00be\u00d1\u0081\u00d0\u00b8\u00d0\u00bb. \u00d0\u00af \u00d0\u00bd\u00d0\u00b5 \u00d0\u00b1\u00d1\u0083\u00d0\u00b4\u00d1\u0083 \u00d0\u00b3\u00d0\u00be\u00d0\u00b2\u00d0\u00be\u00d1\u0080\u00d0\u00b8\u00d1\u0082\u00d1\u008c: \u00c2\u00ab\u00d0\u0097\u00d0\u00b0\u00d0\u00b1\u00d1\u0083\u00d0\u00b4\u00d1\u008c \u00d0\u00b8 \u00d0\u00b4\u00d0\u00b2\u00d0\u00b8\u00d0\u00b3\u00d0\u00b0\u00d0\u00b9\u00d1\u0081\u00d1\u008f \u00d0\u00b4\u00d0\u00b0\u00d0\u00bb\u00d1\u008c\u00d1\u0088\u00d0\u00b5\u00c2\u00bb. \u00d0\u00ad\u00d1\u0082\u00d0\u00be \u00d0\u00be\u00d0\u00bf\u00d0\u00b0\u00d1\u0081\u00d0\u00bd\u00d0\u00be \u00d0\u00b8 \u00d0\u00bd\u00d0\u00b5\u00d0\u00bf\u00d1\u0080\u00d0\u00b0\u00d0\u00b2\u00d0\u00b4\u00d0\u00b0.\n\n\u00d0\u0092\u00d0\u00bc\u00d0\u00b5\u00d1\u0081\u00d1\u0082\u00d0\u00be \u00d1\u008d\u00d1\u0082\u00d0\u00be\u00d0\u00b3\u00d0\u00be \u00d0\u00bc\u00d1\u008b \u00d0\u00bc\u00d0\u00b5\u00d0\u00b4\u00d0\u00bb\u00d0\u00b5\u00d0\u00bd\u00d0\u00bd\u00d0\u00be \u00d0\u00bf\u00d1\u0080\u00d0\u00b8\u00d0\u00b1\u00d0\u00bb\u00d0\u00b8\u00d0\u00b6\u00d0\u00b0\u00d0\u00b5\u00d0\u00bc\u00d1\u0081\u00d1\u008f \u00d0\u00ba \u00d1\u0082\u00d0\u00be\u00d0\u00b9 \u00d0\u00b1\u00d0\u00be\u00d0\u00bb\u00d0\u00b8, \u00d0\u00ba\u00d0\u00be\u00d1\u0082\u00d0\u00be\u00d1\u0080\u00d0\u00b0\u00d1\u008f \u00d0\u00b2 \u00d1\u0082\u00d0\u00b5\u00d0\u00b1\u00d0\u00b5 \u00d0\u00b6\u00d0\u00b8\u00d0\u00b2\u00d1\u0091\u00d1\u0082. \u00d0\u009c\u00d1\u008b \u00d0\u00ba\u00d0\u00b0\u00d1\u0081\u00d0\u00b0\u00d0\u00b5\u00d0\u00bc\u00d1\u0081\u00d1\u008f \u00d0\u00b5\u00d1\u0091 \u00e2\u0080\u0094 \u00d0\u00b2\u00d0\u00bc\u00d0\u00b5\u00d1\u0081\u00d1\u0082\u00d0\u00b5. \u00d0\u0098 \u00d0\u00ba\u00d0\u00be\u00d0\u00b3\u00d0\u00b4\u00d0\u00b0 \u00d1\u0082\u00d1\u008b \u00d0\u00bd\u00d0\u00b5 \u00d0\u00be\u00d0\u00b4\u00d0\u00bd\u00d0\u00b0, \u00d1\u008d\u00d1\u0082\u00d0\u00be \u00d1\u0083\u00d0\u00b6\u00d0\u00b5 \u00d0\u00bd\u00d0\u00b5 \u00d1\u0082\u00d0\u00b0\u00d0\u00ba \u00d1\u0081\u00d1\u0082\u00d1\u0080\u00d0\u00b0\u00d1\u0088\u00d0\u00bd\u00d0\u00be.\n\n\u00d0\u00a2\u00d1\u008b \u00d1\u0081\u00d0\u00b0\u00d0\u00bc \u00d0\u00b2\u00d1\u008b\u00d0\u00b1\u00d0\u00b8\u00d1\u0080\u00d0\u00b0\u00d0\u00b5\u00d1\u0088\u00d1\u008c, \u00d0\u00be \u00d1\u0087\u00d1\u0091\u00d0\u00bc \u00d0\u00b3\u00d0\u00be\u00d0\u00b2\u00d0\u00be\u00d1\u0080\u00d0\u00b8\u00d1\u0082\u00d1\u008c. \u00d0\u00a2\u00d1\u008b \u00d1\u0081\u00d0\u00b0\u00d0\u00bc \u00d0\u00b2\u00d1\u008b\u00d0\u00b1\u00d0\u00b8\u00d1\u0080\u00d0\u00b0\u00d0\u00b5\u00d1\u0088\u00d1\u008c \u00d1\u0082\u00d0\u00b5\u00d0\u00bc\u00d0\u00bf. \u00d0\u0095\u00d1\u0081\u00d0\u00bb\u00d0\u00b8 \u00d1\u0085\u00d0\u00be\u00d1\u0087\u00d0\u00b5\u00d1\u0088\u00d1\u008c \u00d0\u00be\u00d1\u0081\u00d1\u0082\u00d0\u00b0\u00d0\u00bd\u00d0\u00be\u00d0\u00b2\u00d0\u00b8\u00d1\u0082\u00d1\u008c\u00d1\u0081\u00d1\u008f \u00e2\u0080\u0094 \u00d0\u00bc\u00d1\u008b \u00d0\u00be\u00d1\u0081\u00d1\u0082\u00d0\u00b0\u00d0\u00bd\u00d0\u00be\u00d0\u00b2\u00d0\u00b8\u00d0\u00bc\u00d1\u0081\u00d1\u008f. \u00d0\u00ad\u00d1\u0082\u00d0\u00be \u00d1\u0082\u00d0\u00b2\u00d0\u00be\u00d1\u0091 \u00d0\u00b2\u00d1\u0080\u00d0\u00b5\u00d0\u00bc\u00d1\u008f. \u00d0\u00a2\u00d0\u00b2\u00d0\u00be\u00d1\u0091 \u00d0\u00bf\u00d1\u0080\u00d0\u00be\u00d1\u0081\u00d1\u0082\u00d1\u0080\u00d0\u00b0\u00d0\u00bd\u00d1\u0081\u00d1\u0082\u00d0\u00b2\u00d0\u00be.\n\n\u00d0\u009d\u00d0\u00b8\u00d0\u00ba\u00d0\u00b0\u00d0\u00ba\u00d0\u00be\u00d0\u00b9 \u00d0\u00bc\u00d0\u00b0\u00d0\u00b3\u00d0\u00b8\u00d0\u00b8. \u00d0\u009d\u00d0\u00b8\u00d0\u00ba\u00d0\u00b0\u00d0\u00ba\u00d0\u00be\u00d0\u00b9 \u00c2\u00ab\u00d0\u00b2\u00d0\u00be\u00d0\u00bb\u00d1\u0088\u00d0\u00b5\u00d0\u00b1\u00d0\u00bd\u00d0\u00be\u00d0\u00b9 \u00d1\u0082\u00d0\u00b0\u00d0\u00b1\u00d0\u00bb\u00d0\u00b5\u00d1\u0082\u00d0\u00ba\u00d0\u00b8\u00c2\u00bb. \u00d0\u009f\u00d1\u0080\u00d0\u00be\u00d1\u0081\u00d1\u0082\u00d0\u00be \u00d1\u0087\u00d0\u00b5\u00d1\u0081\u00d1\u0082\u00d0\u00bd\u00d0\u00b0\u00d1\u008f \u00d1\u0080\u00d0\u00b0\u00d0\u00b1\u00d0\u00be\u00d1\u0082\u00d0\u00b0 \u00d1\u0081 \u00d1\u0082\u00d0\u00b5\u00d0\u00bc, \u00d1\u0087\u00d1\u0082\u00d0\u00be \u00d0\u00b2\u00d0\u00bd\u00d1\u0083\u00d1\u0082\u00d1\u0080\u00d0\u00b8.\n\n\u00d0\u009c\u00d0\u00bd\u00d0\u00be\u00d0\u00b3\u00d0\u00b8\u00d0\u00b5 \u00d0\u00bb\u00d1\u008e\u00d0\u00b4\u00d0\u00b8 \u00d0\u00b3\u00d0\u00be\u00d0\u00b2\u00d0\u00be\u00d1\u0080\u00d1\u008f\u00d1\u0082 \u00d0\u00bf\u00d0\u00be\u00d1\u0082\u00d0\u00be\u00d0\u00bc: \u00c2\u00ab\u00d0\u00af \u00d0\u00bd\u00d0\u00b5 \u00d0\u00b4\u00d1\u0083\u00d0\u00bc\u00d0\u00b0\u00d0\u00bb\u00d0\u00b0, \u00d1\u0087\u00d1\u0082\u00d0\u00be \u00d1\u008d\u00d1\u0082\u00d0\u00be \u00d0\u00bc\u00d0\u00be\u00d0\u00b6\u00d0\u00b5\u00d1\u0082 \u00d0\u00b1\u00d1\u008b\u00d1\u0082\u00d1\u008c \u00d1\u0082\u00d0\u00b0\u00d0\u00ba \u00d0\u00bf\u00d1\u0080\u00d0\u00be\u00d1\u0081\u00d1\u0082\u00d0\u00be. \u00d0\u00a2\u00d0\u00b0\u00d0\u00ba \u00d1\u0087\u00d0\u00b5\u00d0\u00bb\u00d0\u00be\u00d0\u00b2\u00d0\u00b5\u00d1\u0087\u00d0\u00bd\u00d0\u00be\u00c2\u00bb.\n\n\u00d0\u0095\u00d1\u0081\u00d0\u00bb\u00d0\u00b8 \u00d0\u00b3\u00d0\u00be\u00d1\u0082\u00d0\u00be\u00d0\u00b2\u00d0\u00b0 \u00d0\u00bf\u00d0\u00be\u00d0\u00bf\u00d1\u0080\u00d0\u00be\u00d0\u00b1\u00d0\u00be\u00d0\u00b2\u00d0\u00b0\u00d1\u0082\u00d1\u008c \u00e2\u0080\u0094 \u00d0\u00bd\u00d0\u00b0\u00d0\u00bf\u00d0\u00b8\u00d1\u0088\u00d0\u00b8.\n\n\u00d0\u00a7\u00d1\u0082\u00d0\u00be \u00d1\u0082\u00d1\u008b \u00d1\u0081\u00d0\u00b5\u00d0\u00b9\u00d1\u0087\u00d0\u00b0\u00d1\u0081 \u00d1\u0087\u00d1\u0083\u00d0\u00b2\u00d1\u0081\u00d1\u0082\u00d0\u00b2\u00d1\u0083\u00d0\u00b5\u00d1\u0088\u00d1\u008c, \u00d0\u00ba\u00d0\u00be\u00d0\u00b3\u00d0\u00b4\u00d0\u00b0 \u00d0\u00b4\u00d1\u0083\u00d0\u00bc\u00d0\u00b0\u00d0\u00b5\u00d1\u0088\u00d1\u008c \u00d0\u00be \u00d1\u0082\u00d0\u00be\u00d0\u00bc, \u00d1\u0087\u00d1\u0082\u00d0\u00be\u00d0\u00b1\u00d1\u008b \u00d0\u00bf\u00d0\u00be\u00d0\u00b3\u00d0\u00be\u00d0\u00b2\u00d0\u00be\u00d1\u0080\u00d0\u00b8\u00d1\u0082\u00d1\u008c \u00d1\u0081 \u00d0\u00ba\u00d0\u00b5\u00d0\u00bc-\u00d1\u0082\u00d0\u00be \u00d0\u00bf\u00d1\u0080\u00d0\u00be \u00d1\u0081\u00d0\u00b2\u00d0\u00be\u00d1\u0091? \u00f0\u009f\u008c\u00bf",
